# TECHOPRINT 2026 - Environment Configuration

# Server Configuration
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Database Configuration
DB_HOST=localhost
DB_PORT=27017
DB_NAME=techoprint_global
DB_USER=
DB_PASSWORD=

# JWT Secret (Generate a strong 64-character key)
JWT_SECRET=techoprint2026supersecretkeygenerateyouruniquekeyhere123456789
JWT_EXPIRES=7d

# Encryption
AES_KEY=techoprint2026aes256encryptionkey123456
ENCRYPTION_ENABLED=true

# Multi-Currency Configuration
DEFAULT_CURRENCY=IQD
SUPPORTED_CURRENCIES=IQD,USD
EXCHANGE_RATE_USD=1450

# OCR Configuration
OCR_API_KEY=
OCR_ENDPOINT=

# Maps Configuration
GOOGLE_MAPS_API_KEY=
LEAFLET_TILES_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,doc,docx

# WebSocket Configuration
WS_PING_INTERVAL=30000
WS_TIMEOUT=60000

# Backup Configuration
BACKUP_INTERVAL=21600000
BACKUP_PATH=./backups

# Email Configuration (Optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@techoprint.com

# Security
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
CORS_ORIGIN=*

# Features
ENABLE_OCR=true
ENABLE_GPS_TRACKING=true
ENABLE_NOTIFICATIONS=true
ENABLE_ANALYTICS=true